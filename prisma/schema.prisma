generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  user
  admin
}

enum UserStatus {
  active
  banned
}

enum BillingMode {
  newapi_ratio
  detailed_token
  fixed
}

enum BillStatus {
  pending
  success
  failed
  refunded
  estimated
}

enum BalanceLogType {
  redeem
  pre_hold
  refund_hold
  final_charge
  extra_deduct
  admin_add
  admin_reduce
}

enum RedeemCodeStatus {
  unused
  used
  disabled
  expired
}

enum AnnouncementType {
  global
  dashboard
  maintenance
  model
}

model User {
  id            String     @id @default(cuid())
  email         String?    @unique
  phone         String?    @unique
  passwordHash  String
  nickname      String?
  avatar        String?
  balance       Decimal    @default(0) @db.Decimal(18, 6)
  frozenBalance Decimal    @default(0) @db.Decimal(18, 6)
  status        UserStatus @default(active)
  role          UserRole   @default(user)
  lastLoginAt   DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  conversations      Conversation[]
  messages           Message[]
  chatBills          ChatBill[]
  balanceLogs        BalanceLog[]
  usedRedeemCodes    RedeemCode[]   @relation("RedeemCodeUsedBy")
  createdRedeemCodes RedeemCode[]   @relation("RedeemCodeCreatedBy")

  @@index([role, status])
  @@index([createdAt])
}

model AiModel {
  id              String  @id @default(cuid())
  name            String
  modelKey        String  @unique
  newapiModelName String
  provider        String?
  description     String?
  enabled         Boolean @default(true)
  visible         Boolean @default(true)
  sort            Int     @default(0)

  billingMode     BillingMode @default(newapi_ratio)
  quotaType       Int         @default(0)
  modelRatio      Decimal     @default(1) @db.Decimal(18, 6)
  completionRatio Decimal     @default(1) @db.Decimal(18, 6)
  groupRatio      Decimal     @default(1) @db.Decimal(18, 6)
  modelPrice      Decimal     @default(0) @db.Decimal(18, 6)
  quotaToCnyRate  Decimal     @default(0.000015) @db.Decimal(18, 6)

  inputPricePer1kCny       Decimal @default(0) @db.Decimal(18, 6)
  outputPricePer1kCny      Decimal @default(0) @db.Decimal(18, 6)
  cacheReadPricePer1kCny   Decimal @default(0) @db.Decimal(18, 6)
  cacheWritePricePer1kCny  Decimal @default(0) @db.Decimal(18, 6)
  reasoningPricePer1kCny   Decimal @default(0) @db.Decimal(18, 6)
  imageInputPricePer1kCny  Decimal @default(0) @db.Decimal(18, 6)
  audioInputPricePer1kCny  Decimal @default(0) @db.Decimal(18, 6)
  audioOutputPricePer1kCny Decimal @default(0) @db.Decimal(18, 6)

  fixedCostCny  Decimal @default(0) @db.Decimal(18, 6)
  fixedPriceCny Decimal @default(0) @db.Decimal(18, 6)

  profitRate       Decimal  @default(1.6) @db.Decimal(18, 6)
  depositAmount    Decimal  @default(0.2) @db.Decimal(18, 6)
  minChargeAmount  Decimal  @default(0.001) @db.Decimal(18, 6)
  maxContextTokens Int      @default(32000)
  maxOutputTokens  Int      @default(4096)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  chatBills ChatBill[]

  @@index([enabled, visible, sort])
}

model Conversation {
  id           String   @id @default(cuid())
  userId       String
  title        String
  modelKey     String
  systemPrompt String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  Message[]
  chatBills ChatBill[]

  @@index([userId, updatedAt])
  @@index([modelKey])
}

model Message {
  id               String   @id @default(cuid())
  conversationId   String
  userId           String
  role             String
  content          String
  modelKey         String
  promptTokens     Int      @default(0)
  completionTokens Int      @default(0)
  totalTokens      Int      @default(0)
  cachedTokens     Int      @default(0)
  reasoningTokens  Int      @default(0)
  imageTokens      Int      @default(0)
  audioTokens      Int      @default(0)
  billId           String?
  createdAt        DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  bill         ChatBill?    @relation(fields: [billId], references: [id], onDelete: SetNull)

  @@index([conversationId, createdAt])
  @@index([userId, createdAt])
  @@index([billId])
}

model ChatBill {
  id              String      @id @default(cuid())
  requestId       String      @unique
  userId          String
  conversationId  String?
  modelId         String?
  modelKey        String
  newapiModelName String
  billingMode     BillingMode
  quotaType       Int

  promptTokens          Int @default(0)
  completionTokens      Int @default(0)
  totalTokens           Int @default(0)
  cachedTokens          Int @default(0)
  nonCachedPromptTokens Int @default(0)
  reasoningTokens       Int @default(0)
  imageTokens           Int @default(0)
  audioInputTokens      Int @default(0)
  audioOutputTokens     Int @default(0)

  modelRatio      Decimal @default(1) @db.Decimal(18, 6)
  completionRatio Decimal @default(1) @db.Decimal(18, 6)
  groupRatio      Decimal @default(1) @db.Decimal(18, 6)
  modelPrice      Decimal @default(0) @db.Decimal(18, 6)
  quotaToCnyRate  Decimal @default(0.000015) @db.Decimal(18, 6)

  quota             Decimal @default(0) @db.Decimal(18, 6)
  costCny           Decimal @default(0) @db.Decimal(18, 6)
  userCostCny       Decimal @default(0) @db.Decimal(18, 6)
  profitCny         Decimal @default(0) @db.Decimal(18, 6)
  profitRate        Decimal @default(1) @db.Decimal(18, 6)
  depositAmount     Decimal @default(0) @db.Decimal(18, 6)
  refundAmount      Decimal @default(0) @db.Decimal(18, 6)
  extraDeductAmount Decimal @default(0) @db.Decimal(18, 6)

  status        BillStatus @default(pending)
  errorMessage  String?
  rawUsage      Json?
  rawResponseId String?
  createdAt     DateTime   @default(now())
  settledAt     DateTime?

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  model        AiModel?      @relation(fields: [modelId], references: [id], onDelete: SetNull)
  messages     Message[]
  balanceLogs  BalanceLog[]

  @@index([userId, createdAt])
  @@index([conversationId])
  @@index([modelId])
  @@index([status, createdAt])
}

model BalanceLog {
  id            String         @id @default(cuid())
  userId        String
  billId        String?
  redeemCodeId  String?
  type          BalanceLogType
  amount        Decimal        @db.Decimal(18, 6)
  balanceBefore Decimal        @db.Decimal(18, 6)
  balanceAfter  Decimal        @db.Decimal(18, 6)
  frozenBefore  Decimal        @default(0) @db.Decimal(18, 6)
  frozenAfter   Decimal        @default(0) @db.Decimal(18, 6)
  remark        String?
  createdAt     DateTime       @default(now())

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  bill       ChatBill?   @relation(fields: [billId], references: [id], onDelete: SetNull)
  redeemCode RedeemCode? @relation(fields: [redeemCodeId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([billId])
  @@index([redeemCodeId])
  @@index([type, createdAt])
}

model RedeemCode {
  id              String           @id @default(cuid())
  code            String           @unique
  amount          Decimal          @db.Decimal(18, 6)
  status          RedeemCodeStatus @default(unused)
  batchNo         String?
  remark          String?
  usedByUserId    String?
  usedAt          DateTime?
  expiredAt       DateTime?
  createdByUserId String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  usedByUser    User?        @relation("RedeemCodeUsedBy", fields: [usedByUserId], references: [id], onDelete: SetNull)
  createdByUser User?        @relation("RedeemCodeCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  balanceLogs   BalanceLog[]

  @@index([status, expiredAt])
  @@index([batchNo])
  @@index([createdAt])
}

model SystemSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String?
  updatedAt   DateTime @updatedAt
}

model Announcement {
  id        String           @id @default(cuid())
  title     String
  content   String
  type      AnnouncementType
  enabled   Boolean          @default(true)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([type, enabled, createdAt])
}
